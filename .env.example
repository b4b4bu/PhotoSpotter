# Database
# For local dev (app running on host, Postgres in Docker):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/photospotter"
# For Docker Compose (both app and db in containers):
# DATABASE_URL="postgresql://postgres:postgres@db:5432/photospotter"

# Auth
JWT_SECRET="change-me-in-production"

# External APIs (required for spot discovery and weather — Phase 1+)
FLICKR_API_KEY=""
OPENWEATHERMAP_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
